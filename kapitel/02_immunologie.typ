  columns: (auto, 1fr, 1fr),
  stroke: 0.5pt + gray,
  inset: 6pt,
  table.header([*Merkmal*], [*Bakterien*], [*Viren*]),
  [Aufbau], [Einzeller mit eigenem Stoffwechsel, Kernäquivalent ohne echten Zellkern (Prokaryonten)], [kleine Infektionsträger ohne eigenen Stoffwechsel, DNA oder RNA],
  [Vermehrung], [wirtsunabhängig durch Zellteilung], [nur mit Wirtsorganismus/Wirtszelle],
